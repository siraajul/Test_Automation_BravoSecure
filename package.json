{
  "name": "test_automation_bravosecure",
  "version": "1.0.0",
  "description": "Appium + WebdriverIO automation for the BravoSecure Android app",
  "main": "index.js",
  "scripts": {
    "connect": "bash scripts/connect-device.sh",
    "doctor": "appium driver doctor uiautomator2",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run connect",
    "test": "wdio run ./wdio.conf.ts",
    "test:smoke": "npm run connect && wdio run ./wdio.conf.ts --suite smoke",
    "test:auth": "npm run connect && wdio run ./wdio.conf.ts --suite auth",
    "test:client": "npm run connect && wdio run ./wdio.conf.ts --suite client",
    "test:cpo": "npm run connect && wdio run ./wdio.conf.ts --suite cpo",
    "test:regression": "npm run connect && wdio run ./wdio.conf.ts --suite regression",
    "test:comms": "wdio run ./wdio.multiremote.conf.ts",
    "test:admin": "playwright test",
    "inject:session": "bash scripts/inject-session.sh",
    "install:app": "bash scripts/install-app.sh",
    "install:browsers": "playwright install chromium",
    "test:core": "jest --config jest.config.js --testPathPattern '\\.core\\.test\\.'",
    "test:api": "jest --config jest.config.js --testPathPattern '\\.api\\.test\\.' --runInBand",
    "test:headless": "jest --config jest.config.js --runInBand",
    "report": "allure generate allure-results --clean -o allure-report && allure open allure-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@noble/hashes": "^2.2.0",
    "@playwright/test": "^1.61.0",
    "@privacyresearch/libsignal-protocol-typescript": "^0.0.16",
    "@types/jest": "^29.5.14",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "@wdio/allure-reporter": "^9.29.0",
    "@wdio/appium-service": "^9.29.0",
    "@wdio/cli": "^9.29.0",
    "@wdio/local-runner": "^9.29.0",
    "@wdio/mocha-framework": "^9.29.0",
    "@wdio/spec-reporter": "^9.29.0",
    "@wdio/types": "^9.29.0",
    "allure-commandline": "^2.43.0",
    "appium": "^3.5.2",
    "appium-uiautomator2-driver": "^7.6.2",
    "dotenv": "^17.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "webdriverio": "^9.29.0"
  }
}
