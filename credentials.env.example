# Copy to credentials.env and fill in. credentials.env is gitignored.

# CLIENT accounts (mobile). client1 = primary; client2/3 for multi-device.
CLIENT1_EMAIL=
CLIENT1_PHONE=
CLIENT1_PASSWORD=
CLIENT2_EMAIL=
CLIENT2_PHONE=
CLIENT2_PASSWORD=
CLIENT3_EMAIL=
CLIENT3_PHONE=
CLIENT3_PASSWORD=

# Encrypted chat-backup / restore password (RESTORE BACKUP screen).
BACKUP_PASSWORD=

# CPO (Close Protection Officer) account — operator/supply side.
CPO_EMAIL=
CPO_PASSWORD=

# ADMIN (web "Bravo Ops Console") — Playwright. Phone + password + OTP (2FA).
ADMIN_URL=
ADMIN_USER=
ADMIN_PASSWORD=
ADMIN_OTP=

# Dubai / UAE region operator accounts
DUBAI_AGENT_EMAIL=
DUBAI_AGENT_PASSWORD=
DUBAI_CPO1_EMAIL=
DUBAI_CPO1_PASSWORD=
DUBAI_CPO2_EMAIL=
DUBAI_CPO2_PASSWORD=

# Organization / corporate admin
ORG_EMAIL=
ORG_PASSWORD=

# Device lockscreen / app PIN for the biometric "Use PIN" fallback.
DEVICE_PIN=

# Device roster (ADB serials)
ANDROID_DEVICE=
BLUESTACKS_1=
BLUESTACKS_2=
